datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id               Int                @id @default(autoincrement())
  name             String
  address          String
  contact          String
  deals            Deal[]
  printingServices PrintingService[]
}

model Board {
  id             Int       @id @default(autoincrement())
  size           String
  location       String
  frontSide      String
  price          Float
  status         String
  availableDate  DateTime?
  deals          Deal[]
  reminders      Reminder[]
}

model Deal {
  id         Int          @id @default(autoincrement())
  clientId   Int
  boardId    Int
  startDate  DateTime
  endDate    DateTime
  paymentType String
  amount     Float
  paidAmount Float
  client     Client       @relation(fields: [clientId], references: [id])
  board      Board        @relation(fields: [boardId], references: [id])
  installments Installment[]
}

model Installment {
  id      Int    @id @default(autoincrement())
  dealId  Int
  dueDate DateTime
  amount  Float
  status  String
  deal    Deal   @relation(fields: [dealId], references: [id])
}

model PrintingService {
  id        Int     @id @default(autoincrement())
  clientId  Int
  printingType String
  details   String?
  price     Float
  status    String
  client    Client  @relation(fields: [clientId], references: [id])
}

model Reminder {
  id          Int      @id @default(autoincrement())
  boardId     Int
  reminderDate DateTime
  message     String
  status      String
  board       Board    @relation(fields: [boardId], references: [id])
}
