datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


// enums 
enum BOARD_STATUS {
  AVAILABLE
  OCCUPIED
}
model Client {
  id               Int                @id @default(autoincrement())
  name             String
  address          String
  contact          String
  deals            Deal[]
  printingServices PrintingService[]
}

model Board {
  id             Int       @id @default(autoincrement())
  size           String
  location       String
  frontSide      String
  price          Float
  status         BOARD_STATUS @default(AVAILABLE)
  availableDate  DateTime?
  dealBoards     DealBoard[]
  reminders      Reminder[]
}

model Deal {
  id         Int          @id @default(autoincrement())
  clientId   Int
  startDate  DateTime
  endDate    DateTime
  amount     Float
  paidAmount Float
  remainingAmount Float
  client     Client       @relation(fields: [clientId], references: [id])
  dealBoards DealBoard[]
  installments Installment[]
}

model DealBoard {
  id      Int   @id @default(autoincrement())
  dealId  Int
  boardId Int
  startDate DateTime @default(now())
  endDate   DateTime @default(now())
  deal    Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  board   Board @relation(fields: [boardId], references: [id])

  @@unique([dealId, boardId])
}

model Installment {
  id      Int    @id @default(autoincrement())
  dealId  Int
  amount  Float
  deal    Deal   @relation(fields: [dealId], references: [id])
  createdAt DateTime @default(now())
}

model PrintingService {
  id        Int     @id @default(autoincrement())
  clientId  Int
  printingType String
  details   String?
  price     Float
  status    String
  client    Client  @relation(fields: [clientId], references: [id])
}

model Reminder {
  id          Int      @id @default(autoincrement())
  boardId     Int
  reminderDate DateTime
  message     String
  status      String
  board       Board    @relation(fields: [boardId], references: [id])
}
